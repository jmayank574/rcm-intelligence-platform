{
  "datasets": [
    {
      "name": "revenue_gap_by_state",
      "displayName": "Revenue Gap by State",
      "queryLines": [
        "SELECT\n",
        "  provider_state,\n",
        "  total_revenue_gap\n",
        "FROM\n",
        "  rcm_platform.rcm_gold.kpi_by_state\n",
        "ORDER BY\n",
        "  total_revenue_gap DESC\n",
        "LIMIT 20"
      ],
      "columns": [
        {
          "displayName": "Revenue Gap (Billions)",
          "description": "Total revenue gap converted to billions",
          "expression": "`total_revenue_gap` / 1000000000"
        }
      ]
    },
    {
      "name": "ea019936",
      "displayName": "fact_claims",
      "queryLines": [
        "SELECT * FROM rcm_platform.rcm_gold.fact_claims"
      ]
    },
    {
      "name": "32251241",
      "displayName": "kpi_by_state",
      "queryLines": [
        "SELECT * FROM rcm_platform.rcm_gold.kpi_by_state\r\n",
        "ORDER BY total_revenue_gap DESC\r\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "a9e25ba2",
      "displayName": "kpi_by_drg",
      "queryLines": [
        "SELECT * FROM rcm_platform.rcm_gold.kpi_by_drg\r\n",
        "ORDER BY total_revenue_gap DESC\r\n",
        "LIMIT 15"
      ],
      "columns": [
        {
          "displayName": "Revenue Gap (Billions)",
          "description": "Total revenue gap in billions",
          "expression": "`total_revenue_gap` / 1000000000"
        }
      ]
    },
    {
      "name": "199c9cd6",
      "displayName": "ar_aging_buckets",
      "queryLines": [
        "SELECT * FROM rcm_platform.rcm_gold.ar_aging_buckets"
      ],
      "columns": [
        {
          "displayName": "Revenue at Risk (Billions)",
          "description": "Revenue at risk converted to billions for easier visualization",
          "expression": "`revenue_at_risk` / 1000000000"
        }
      ]
    },
    {
      "name": "6ce5bc68",
      "displayName": "hospital_scorecard",
      "queryLines": [
        "SELECT * FROM rcm_platform.rcm_gold.hospital_scorecard"
      ]
    },
    {
      "name": "52c4fb79",
      "displayName": "denial_risk_scores",
      "queryLines": [
        "SELECT * FROM rcm_platform.rcm_gold.denial_risk_scores"
      ]
    },
    {
      "name": "kpi_summary",
      "displayName": "KPI Summary",
      "queryLines": [
        "SELECT\n",
        "  SUM(hospital_count) as total_hospitals,\n",
        "  SUM(total_discharges) as total_claims,\n",
        "  AVG(avg_revenue_gap_pct) as avg_gap_pct,\n",
        "  AVG(underpayment_rate_pct) as avg_underpayment_rate,\n",
        "  SUM(total_revenue_gap) as total_revenue_gap\n",
        "FROM\n",
        "  rcm_platform.rcm_gold.kpi_by_state"
      ],
      "catalog": "rcm_platform",
      "schema": "rcm_gold"
    },
    {
      "name": "ar_aging",
      "displayName": "AR Aging Analysis",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  ar_aging_buckets\n",
        "ORDER BY\n",
        "  aging_bucket_order"
      ],
      "catalog": "rcm_platform",
      "schema": "rcm_gold"
    },
    {
      "name": "hospital_perf",
      "displayName": "Hospital Performance",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  hospital_scorecard\n",
        "ORDER BY\n",
        "  total_revenue_gap DESC\n",
        "LIMIT 25"
      ],
      "catalog": "rcm_platform",
      "schema": "rcm_gold"
    },
    {
      "name": "denial_risk_dist",
      "displayName": "Denial Risk Distribution",
      "queryLines": [
        "SELECT\n",
        "  risk_category,\n",
        "  COUNT(*) as claim_count\n",
        "FROM\n",
        "  rcm_platform.rcm_gold.denial_risk_scores\n",
        "GROUP BY\n",
        "  risk_category"
      ],
      "catalog": "rcm_platform",
      "schema": "rcm_gold"
    }
  ],
